# WAHA instance URL (your WAHA host + port)
WAHA_API_URL=http://localhost:3000

# API key for WAHA (set in your WAHA docker-compose.yml)
WAHA_API_KEY=

# Session name (default: "default")
WAHA_SESSION=default

# Optional: default phone for --self resolution (auto-detected from session if not set)
# WAHA_DEFAULT_PHONE=972501234567
